## TingTingVac 5K CCU Benchmark — Environment Variables

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ttv
POSTGRES_PASSWORD=ttv_pass
POSTGRES_DB=ttv

# Host port for seed script (5432 on Linux VPS, 5434 on Windows if port conflict)
# Linux VPS (default):  POSTGRES_HOST_PORT=5432
# Windows Docker Desktop: POSTGRES_HOST_PORT=5434
POSTGRES_HOST_PORT=5432

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=ttv_jwt_secret_benchmark_2026

# ── Benchmark (k6 scripts) ────────────────────────────────────────────────────
# Docker internal network (when k6 runs inside Docker):
API_BASE_URL=http://ttv_api:3000

# Host network (when k6 runs on host/VPS directly):
# API_BASE_URL=http://localhost:3000

# Bypass Redis session check for load testing
BENCH_TOKEN=benchmark-token-skip-auth

# ── Seed script (runs on host, connects to exposed ports) ─────────────────────
# Linux VPS:
DATABASE_URL=postgresql://ttv:ttv_pass@localhost:5432/ttv
REDIS_GEO_EXTERNAL_URL=redis://localhost:6381

# Windows Docker Desktop (if using port 5434):
# DATABASE_URL=postgresql://ttv:ttv_pass@localhost:5434/ttv
