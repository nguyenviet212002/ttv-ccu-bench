POSTGRES_USER=ttv
POSTGRES_PASSWORD=ttv_pass
POSTGRES_DB=ttv
JWT_SECRET=ttv_jwt_secret_benchmark_2026

# Redis URLs (used by API container — these are internal docker network names)
REDIS_SESSION_URL=redis://redis-session:6379
REDIS_CACHE_URL=redis://redis-cache:6379
REDIS_GEO_URL=redis://redis-geo:6379
REDIS_QUEUE_URL=redis://redis-queue:6379
REDIS_PUBSUB_URL=redis://redis-pubsub:6379

# External Redis URLs (used by seed script and k6 on host)
REDIS_GEO_HOST=localhost
REDIS_GEO_PORT=6381
REDIS_SESSION_HOST=localhost
REDIS_SESSION_PORT=6379
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6380

# API base URL (for k6 scripts running on host)
# Docker Desktop (WSL2) — dùng localhost
API_BASE_URL=http://localhost:3000

# Docker Toolbox (VirtualBox) — dùng IP VM
# API_BASE_URL=http://192.168.99.100:3000
